# Server Config
PORT=3000

# Supabase / PostgreSQL Connection String
# Example: postgres://postgres.your-supabase-project:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_URL=

# Redis Configuration (caches scanned QR records for 60 seconds). Leave blank to disable caching.
# Format: redis://[:password@]host:port/db (or rediss:// for TLS)
REDIS_URL=redis://localhost:6379/0

# JWT Signing Secret (Generate a strong random key)
JWT_SECRET=super-secret-random-jwt-signing-key

# Secure Encryption Key for AES-GCM (32 bytes generated or SHA-256 derived from this string)
ENCRYPTION_KEY=default-insecure-32-byte-secret-key!

# Redirect Base URL (Base URL used to build short URLs returned to user, e.g. https://qr.chroniqr.com)
REDIRECT_BASE_URL=http://localhost:3000

# Geolocation configuration
GEOIP_DB_PATH=./assets/GeoLite2-City.mmdb

# Length of generated short codes (default 8)
SHORT_CODE_LENGTH=8

# GA4 Debug Mode (true/false)
GA4_DEBUG=false
